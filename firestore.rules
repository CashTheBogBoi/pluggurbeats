rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own profile + everything under their campaigns (incl. events)
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      match /campaigns/{campaignId}/{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // emailIndex is written/read only by Cloud Functions (admin SDK bypasses rules)
    match /emailIndex/{emailId} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
