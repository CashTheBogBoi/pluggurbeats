rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Protected fields — only Cloud Functions (admin SDK) may change these
    function protectedKeys() {
      return ['subscription','pitchCredits','loopCredits','verifiedPuller','verifiedListener','verifiedRole','labelName'];
    }

    // A user's own profile + everything under their campaigns (incl. events)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // On create, the credit/subscription fields must start at their defaults
      // so a user cannot self-grant credits or verification at signup.
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.verifiedPuller == false
        && request.resource.data.subscription.tier == "free"
        && request.resource.data.pitchCredits.balance == 0
        && request.resource.data.pitchCredits.monthlyGrant == 0
        && request.resource.data.loopCredits.balance == 5
        && request.resource.data.loopCredits.monthlyGrant == 5;

      // On update, the client may touch profile fields but NOT protected ones
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedKeys());

      allow delete: if request.auth != null && request.auth.uid == userId;

      // Credit audit trail — client may read its own, writes are Functions-only
      match /creditLedger/{entryId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Verified-library activity (who viewed/downloaded this owner's beats &
      // loops). Owner reads its own live; only Cloud Functions write.
      match /libraryActivity/{actId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Split sheets the producer generated. Owner reads its own; writes +
      // status updates are Cloud Functions only (DocuSign envelopes).
      match /splitSheets/{sheetId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Inbound submissions: beats sent EXCLUSIVELY to this user's requests.
      // The request owner reads its own inbox; only Cloud Functions write.
      match /inboundSubmissions/{subId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /campaigns/{campaignId}/{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // emailIndex is written/read only by Cloud Functions (admin SDK bypasses rules)
    match /emailIndex/{emailId} {
      allow read, write: if false;
    }

    // verifiedEmailList — server-side only. Populated by setVerifiedRole,
    // read by submitCampaign/submitLoop to notify verified requesters.
    // Client never reads or writes this collection.
    match /verifiedEmailList/{uid} {
      allow read, write: if false;
    }

    // Stripe customer→uid mapping — Cloud Functions only
    match /stripeCustomers/{customerId} {
      allow read, write: if false;
    }

    // DocuSign envelopeId → {uid, sheetId} lookup — Cloud Functions only
    match /dsEnvelopes/{envelopeId} {
      allow read, write: if false;
    }

    // Loops — makers can read/create their own; verifiedPullers can read all.
    // Updates and deletes are Cloud Functions only (admin SDK).
    match /loops/{loopId} {
      allow read: if request.auth != null
        && (resource.data.makerUid == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verifiedPuller == true);
      allow create: if request.auth != null
        && request.resource.data.makerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Loop claims — Cloud Functions only (admin SDK bypasses rules)
    match /loopClaims/{claimId} {
      allow read, write: if false;
    }

    // Campaign requests — verified users and subscribers may read the open
    // feed live (the doc holds only denormalized public identity; requester
    // contact info lives in users docs and never lands here). All writes and
    // counter updates stay Cloud Functions only.
    match /campaignRequests/{requestId} {
      allow read: if request.auth != null;
      allow write: if false;

      // View dedupe markers stay Cloud Functions only.
      match /viewers/{viewerId} {
        allow read, write: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
