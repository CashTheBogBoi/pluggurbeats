rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Producers can only read/write their own beat uploads
    match /beats/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Profile avatars — owner read/write; staff read via signed URLs from functions
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Pitch ZIPs are generated and served by Cloud Functions only
    match /pitches/{allPaths=**} {
      allow read, write: if false;
    }

    // Loop audio — makers upload and can read back their own files.
    // All other reads (verifiedPuller downloads) go through the pullLoop
    // Cloud Function which returns a short-lived signed URL.
    match /loops/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
